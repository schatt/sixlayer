# Swift Package Manager
#
# Workspace state (recreated when opening in Xcode; ignore to avoid sync noise)
.swiftpm/

# Build artifacts
.build/
.build-clean/
DerivedData/
build/
.ci-derived-data/
.ci-spm/
artifacts/

# Compiled objects and binaries
*.o
*.a
*.so
*.dylib
*.dll
*.exe

# Swift build artifacts
*.swiftmodule
*.swiftdoc
*.dSYM/
*.app
*.ipa
*.dmg

# Swift Package Manager
# Add this line if you want to avoid checking in source code from Swift Package Manager dependencies.
# Packages/
# Package.pins
# Package.resolved

# Xcode (if using Xcode to edit the package)
xcuserdata/

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# Xcode test result bundles (do not write -resultBundlePath into repo root)
*.xcresult

# Test performance analysis output files
test_performance_*.json
slow_test_suites.json
test_output.log

# Local agent / CLI full logs (tee targets); not for version control
.logs/

# Ephemeral Xcode DerivedData access logs (per-worktree random suffix)
.derived-data-log-*

# Python bytecode (Cursor hook scripts)
.cursor/hooks/__pycache__/
